# Jobilly.ai — Environment Variables
#
# LOCAL DEV: copy this file to `.env.local` and fill in real values. `.env.local` is
# git-ignored and never committed.
#
# PRODUCTION / STAGING: do NOT put real secrets in any .env file that touches git.
# Store them in Doppler or Infisical and inject at runtime/deploy time. This file
# exists purely as documentation of which variables the app expects.

# ---------------------------------------------------------------------------
# Supabase (database, auth, storage, pgvector)
# Google OAuth secret for `supabase config push` (do not commit real values)
GOOGLE_OAUTH_CLIENT_SECRET=
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_ID=

# ---------------------------------------------------------------------------
# AI / Media services
# ---------------------------------------------------------------------------
GEMINI_API_KEY=
# Alias also supported: GOOGLE_API_KEY=
# Optional: Gemini model for welcome-page Joben chat (default: gemini-2.5-flash)
JOBEN_GEMINI_MODEL=
OPENAI_API_KEY=
HEYGEN_API_KEY=
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=
DAILY_API_KEY=
APIFY_API_TOKEN=
# Alias supported by the app if you prefer this name:
APIFY_KEY=
# Optional override for the versioned Fortune 500 company-name CSV.
FORTUNE_500_DATA_URL=

# ---------------------------------------------------------------------------
# Infrastructure / Ops
# ---------------------------------------------------------------------------
# Required in production for login + password-reset rate limiting
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Bearer token for /api/cron/* routes (Vercel Cron sends Authorization: Bearer <CRON_SECRET>)
CRON_SECRET=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
AXIOM_TOKEN=
AXIOM_DATASET=
BETTER_STACK_SOURCE_TOKEN=

# ---------------------------------------------------------------------------
# Payments / Email / Booking
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
RESEND_API_KEY=
# e.g. Jobilly <noreply@yourdomain.com> — used for password reset + career advisory emails
RESEND_FROM_EMAIL=
# IANA timezone for end-of-day application summary emails (default: America/New_York)
APPLICATIONS_DIGEST_TIMEZONE=America/New_York
# Local dev only — Google Meet invite emails are not sent in production
CAREER_ADVISORY_GOOGLE_MEET_URL=
CAREER_ADVISORY_ORGANIZER_EMAIL=
CAL_COM_API_KEY=

# ---------------------------------------------------------------------------
# App config
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
